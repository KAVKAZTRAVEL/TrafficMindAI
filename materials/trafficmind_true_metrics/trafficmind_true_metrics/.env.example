# TrafficMind TrueMetrics
PORT=8088
PUBLIC_TRACKING_ORIGIN=*
COLLECTOR_SECRET=change_me_long_random_secret

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=trafficmind

# Optional PostHog forwarding
POSTHOG_ENABLED=true
POSTHOG_HOST=http://localhost:8000
POSTHOG_PROJECT_API_KEY=ph_project_token_here

# Privacy / accuracy
IP_HASH_SALT=change_me_ip_salt
BOT_UA_DENYLIST=bot,crawler,spider,preview,facebookexternalhit,slurp,semrush,ahrefs,headless
