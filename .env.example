ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://trafficmind:trafficmind@postgres:5432/trafficmind
SYNC_DATABASE_URL=postgresql://trafficmind:trafficmind@postgres:5432/trafficmind
REDIS_URL=redis://redis:6379/0
TELEGRAM_BOT_TOKEN=
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
STRIPE_SECRET_KEY=
OPENAI_API_KEY=
ADMIN_TELEGRAM_IDS=
PUBLIC_BASE_URL=http://localhost:8000
TRACKER_ALLOWED_ORIGINS=*
TRACKER_RATE_LIMIT_PER_MINUTE=120
TRIAL_DAYS=7

# OAuth apps for one-click integrations.
# Google covers GA4, Search Console, Google Ads and YouTube.
